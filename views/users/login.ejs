<% layout("/layouts/boilerplate") %>

<style>
  .auth-page {
    min-height: calc(100vh - 12rem);
    display: grid;
    place-items: center;
    padding: 2rem 0 3rem;
  }

  .auth-card {
    width: min(100%, 460px);
    border: 1px solid #e8e8e8;
    border-radius: 1rem;
    background-color: #fff;
    padding: 1.5rem;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.06);
  }

  .auth-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.35rem;
  }

  .auth-subtitle {
    color: #666;
    margin-bottom: 1.35rem;
  }

  .auth-card .form-control {
    border-radius: 0.75rem;
    padding: 0.7rem 0.85rem;
  }

  .auth-card .form-control:focus {
    border-color: #fe424d;
    box-shadow: 0 0 0 0.15rem rgba(254, 66, 77, 0.12);
  }

  .auth-btn {
    width: 100%;
    border: none;
    border-radius: 0.75rem;
    background-color: #fe424d;
    color: white;
    font-weight: 700;
    padding: 0.72rem 1rem;
  }

  .auth-footer {
    color: #666;
    font-size: 0.95rem;
    margin: 1rem 0 0;
    text-align: center;
  }

  .auth-footer a {
    color: #fe424d;
    font-weight: 700;
    text-decoration: none;
  }

  body.dark-mode .auth-card {
    background-color: #1e1e1e;
    border-color: #333;
  }

  body.dark-mode .auth-subtitle,
  body.dark-mode .auth-footer {
    color: #ddd;
  }
</style>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Login</h1>
    <p class="auth-subtitle">Welcome back to WonderLust.</p>

    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input name="username" id="username" type="text" class="form-control" autocomplete="username" required>
        <div class="invalid-feedback">Please enter your username.</div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label">Password</label>
        <input name="password" id="password" type="password" class="form-control" autocomplete="current-password" required>
        <div class="invalid-feedback">Please enter your password.</div>
      </div>

      <button class="auth-btn" type="submit">Login</button>
    </form>

    <p class="auth-footer">
      New here? <a href="/signup">Create an account</a>
    </p>
  </div>
</div>
