<% layout("/layouts/boilerplate") %>

<style>
  .wishlist-page {
    padding: 1.75rem 0 3rem;
  }

  .wishlist-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.35rem;
  }

  .wishlist-title {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    margin-bottom: 0.35rem;
  }

  .wishlist-subtitle {
    color: #666;
    margin-bottom: 0;
  }

  .wishlist-count {
    border: 1px solid #e8e8e8;
    border-radius: 999px;
    color: #444;
    font-weight: 700;
    padding: 0.45rem 0.85rem;
    white-space: nowrap;
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .wishlist-link {
    color: inherit;
    text-decoration: none;
  }

  .wishlist-card {
    height: 100%;
    border: 1px solid #e8e8e8;
    border-radius: 1rem;
    background: #fff;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .wishlist-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .wishlist-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .wishlist-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease, filter 0.35s ease;
  }

  .wishlist-card:hover .wishlist-img {
    transform: scale(1.04);
    filter: brightness(0.95);
  }

  .saved-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: white;
    color: #fe424d;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
  }

  .wishlist-body {
    padding: 0.95rem;
  }

  .wishlist-card-title {
    color: #222;
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 0.45rem;
  }

  .wishlist-meta {
    color: #666;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
  }

  .wishlist-price {
    color: #333;
    font-weight: 700;
    margin-bottom: 0;
  }

  .empty-wishlist {
    border: 1px dashed #d8d8d8;
    border-radius: 1rem;
    padding: 2rem;
    text-align: center;
  }

  .empty-wishlist i {
    color: #fe424d;
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .empty-wishlist h2 {
    font-size: 1.45rem;
    font-weight: 800;
    margin-bottom: 0.45rem;
  }

  .empty-wishlist p {
    color: #666;
    margin-bottom: 1rem;
  }

  .explore-btn {
    border-radius: 0.75rem;
    background-color: #fe424d;
    border: none;
    color: white;
    font-weight: 700;
    padding: 0.65rem 1.2rem;
    text-decoration: none;
  }

  body.dark-mode .wishlist-card,
  body.dark-mode .empty-wishlist {
    background-color: #1e1e1e;
    border-color: #333;
  }

  body.dark-mode .wishlist-card-title,
  body.dark-mode .wishlist-price {
    color: white;
  }

  body.dark-mode .wishlist-subtitle,
  body.dark-mode .wishlist-meta,
  body.dark-mode .empty-wishlist p,
  body.dark-mode .wishlist-count {
    color: #ddd;
  }

  body.dark-mode .wishlist-count {
    border-color: #333;
  }

  @media (max-width: 576px) {
    .wishlist-header {
      display: block;
    }

    .wishlist-count {
      display: inline-block;
      margin-top: 0.85rem;
    }

    .empty-wishlist {
      padding: 1.5rem 1rem;
    }
  }
</style>

<div class="wishlist-page">
  <div class="wishlist-header">
    <div>
      <h1 class="wishlist-title">Saved Homes</h1>
      <p class="wishlist-subtitle">Your favorite stays, ready when you are.</p>
    </div>

    <span class="wishlist-count">
      <%= wishlist.length %> saved
    </span>
  </div>

  <% if(wishlist.length > 0) { %>
    <div class="wishlist-grid">
      <% for(let listing of wishlist){ %>
        <a href="/listings/<%= listing._id %>" class="wishlist-link">
          <article class="wishlist-card">
            <div class="wishlist-image-wrap">
              <img src="<%= listing.image?.url %>" class="wishlist-img" alt="<%= listing.title %>">
              <span class="saved-badge">
                <i class="fa-solid fa-heart"></i>
              </span>
            </div>

            <div class="wishlist-body">
              <h2 class="wishlist-card-title"><%= listing.title %></h2>

              <p class="wishlist-meta">
                <i class="fa-solid fa-location-dot"></i>
                <span><%= listing.location %>, <%= listing.country %></span>
              </p>

              <p class="wishlist-price">
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
              </p>
            </div>
          </article>
        </a>
      <% } %>
    </div>
  <% } else { %>
    <div class="empty-wishlist">
      <i class="fa-regular fa-heart"></i>
      <h2>No saved homes yet</h2>
      <p>Tap the heart on a stay to keep it here for later.</p>
      <a href="/listings" class="explore-btn">Explore Stays</a>
    </div>
  <% } %>
</div>
