<% layout("/layouts/boilerplate") %>

<style>
  .listing-form-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.75rem 0 3rem;
  }

  .form-header {
    margin-bottom: 1.25rem;
  }

  .form-title {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    margin-bottom: 0.35rem;
  }

  .form-subtitle {
    color: #666;
    margin-bottom: 0;
  }

  .listing-form-card {
    border: 1px solid #e8e8e8;
    border-radius: 1rem;
    background-color: #fff;
    padding: 1.4rem;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.05);
  }

  .form-section {
    border-bottom: 1px solid #ededed;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
  }

  .form-section:last-of-type {
    border-bottom: 0;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .form-section-title {
    font-size: 1.05rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .listing-form-card .form-control,
  .listing-form-card .form-select {
    border-radius: 0.75rem;
    padding: 0.68rem 0.85rem;
  }

  .listing-form-card textarea {
    min-height: 130px;
  }

  .listing-form-card .form-control:focus,
  .listing-form-card .form-select:focus {
    border-color: #fe424d;
    box-shadow: 0 0 0 0.15rem rgba(254, 66, 77, 0.12);
  }

  .current-image-card {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    border: 1px solid #ededed;
    border-radius: 1rem;
    padding: 0.75rem;
    margin-bottom: 1rem;
  }

  .current-image {
    width: 100%;
    height: 145px;
    object-fit: cover;
    border-radius: 0.8rem;
  }

  .current-image-card p {
    color: #666;
    margin-bottom: 0;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }

  .primary-form-btn {
    border: none;
    border-radius: 0.75rem;
    background-color: #fe424d;
    color: white;
    font-weight: 700;
    padding: 0.68rem 1.25rem;
  }

  .secondary-form-btn {
    border-radius: 0.75rem;
    padding: 0.68rem 1.25rem;
  }

  body.dark-mode .listing-form-card {
    background-color: #1e1e1e;
    border-color: #333;
  }

  body.dark-mode .form-subtitle,
  body.dark-mode .current-image-card p {
    color: #ddd;
  }

  body.dark-mode .form-section,
  body.dark-mode .current-image-card {
    border-color: #333;
  }

  @media (max-width: 576px) {
    .listing-form-card {
      padding: 1rem;
    }

    .current-image-card {
      grid-template-columns: 1fr;
    }

    .form-actions {
      flex-direction: column-reverse;
    }

    .form-actions .btn,
    .primary-form-btn {
      width: 100%;
    }
  }
</style>

<div class="listing-form-page">
  <div class="form-header">
    <h1 class="form-title">Edit Your Listing</h1>
    <p class="form-subtitle">Update the details guests see before booking.</p>
  </div>

  <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="listing-form-card needs-validation" enctype="multipart/form-data" novalidate>
    <div class="form-section">
      <h2 class="form-section-title">Basics</h2>

      <div class="row g-3">
        <div class="col-12">
          <label for="title" class="form-label">Title</label>
          <input type="text" id="title" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
          <div class="invalid-feedback">Please enter a title.</div>
        </div>

        <div class="col-12">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="listing[description]" class="form-control" required><%= listing.description %></textarea>
          <div class="invalid-feedback">Please enter a short description.</div>
        </div>
      </div>
    </div>

    <div class="form-section">
      <h2 class="form-section-title">Location and Pricing</h2>

      <div class="row g-3">
        <div class="col-md-4">
          <label for="price" class="form-label">Price per night</label>
          <input type="number" id="price" name="listing[price]" value="<%= listing.price %>" min="0" class="form-control" required>
          <div class="invalid-feedback">Please enter a valid price.</div>
        </div>

        <div class="col-md-4">
          <label for="location" class="form-label">Location</label>
          <input type="text" id="location" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
          <div class="invalid-feedback">Please enter the location.</div>
        </div>

        <div class="col-md-4">
          <label for="country" class="form-label">Country</label>
          <input type="text" id="country" name="listing[country]" value="<%= listing.country %>" class="form-control" required>
          <div class="invalid-feedback">Please enter the country.</div>
        </div>
      </div>
    </div>

    <div class="form-section">
      <h2 class="form-section-title">Photo</h2>

      <div class="current-image-card">
        <img src="<%= listing.image?.url %>" class="current-image" alt="<%= listing.title %>">
        <div>
          <strong>Current listing image</strong>
          <p>Upload a new image only if you want to replace this one.</p>
        </div>
      </div>

      <label for="image" class="form-label">Upload new image</label>
      <input type="file" id="image" name="listing[image]" class="form-control" accept="image/*">
    </div>

    <div class="form-actions">
      <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary secondary-form-btn">Cancel</a>
      <button type="submit" class="primary-form-btn">Update Listing</button>
    </div>
  </form>
</div>
